{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: gcc build active file",
            "command": "mkdir -p \"${fileDirname}/bin\" && /usr/bin/gcc -fdiagnostics-color=always -g \"${file}\" -o \"${fileDirname}/bin/${fileBasenameNoExtension}\"",
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}